{
  "name": "@bookedsolid/lanyard",
  "version": "0.1.0",
  "description": "Switch between Claude OAuth accounts without touching your shell rc files. macOS Keychain–backed credential vault with refresh-token-safe swaps.",
  "license": "MIT",
  "author": "Booked Solid Technology <oss@bookedsolid.tech> (https://bookedsolid.tech)",
  "homepage": "https://github.com/bookedsolidtech/lanyard#readme",
  "bugs": {
    "url": "https://github.com/bookedsolidtech/lanyard/issues"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bookedsolidtech/lanyard.git"
  },
  "bin": {
    "lanyard": "dist/cli/index.js"
  },
  "sideEffects": false,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22"
  },
  "os": [
    "darwin"
  ],
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm build && changeset publish",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "oauth",
    "account-switch",
    "keychain",
    "cli"
  ],
  "dependencies": {
    "env-paths": "^3.0.0",
    "yaml": "^2.7.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@bookedsolid/rea": "latest",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.2.0",
    "obsidian-mcp": "*",
    "prettier": "^3.8.1",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
